# ============================================================
# Local configuration template — SAFE EXAMPLE (no real credentials)
# Copy this file to application.properties and fill in real values.
# The actual application.properties is git-ignored.
# Proyecto AyD2 P2B
# ============================================================

spring.application.name=iam-service

server.port=8081
server.max-http-request-header-size=65536

# ============================================================
# Datasource PostgreSQL
# ============================================================

spring.datasource.url=jdbc:postgresql://localhost:5432/iam_db
spring.datasource.username=your_db_username_here
spring.datasource.password=your_db_password_here
spring.datasource.driver-class-name=org.postgresql.Driver

# ============================================================
# JPA / Hibernate
# ============================================================

spring.jpa.hibernate.ddl-auto=validate
spring.jpa.open-in-view=false
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.jdbc.time_zone=UTC

# Set to false in production
spring.jpa.show-sql=true

# ============================================================
# Flyway
# ============================================================

spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration
spring.flyway.baseline-on-migrate=true

# ============================================================
# Actuator
# ============================================================

management.endpoints.web.exposure.include=health,info
management.endpoint.health.show-details=when_authorized

# ============================================================
# OpenAPI / Swagger
# ============================================================

springdoc.api-docs.path=/v3/api-docs
springdoc.swagger-ui.path=/swagger-ui.html

# ============================================================
# Eureka
# ============================================================

eureka.client.enabled=false

# ============================================================
# Security / JWT
# In production these must come from environment variables or
# AWS Secrets Manager — never commit real values.
# ============================================================

security.jwt.secret=${SECURITY_JWT_SECRET:your_jwt_secret_at_least_32_chars_here}
security.jwt.expiration-minutes=${SECURITY_JWT_EXPIRATION_MINUTES:15}
security.jwt.refresh-expiration-days=${SECURITY_JWT_REFRESH_EXPIRATION_DAYS:7}
security.internal.service-token=${IAM_INTERNAL_SERVICE_TOKEN:}

# ============================================================
# CORS local
# ============================================================

app.cors.allowed-origins=http://localhost:3000
